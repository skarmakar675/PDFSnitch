# Render backend environment variables
# Put these in Render Dashboard > your backend service > Environment.
# Do not commit real passwords or Gmail app passwords.

PDFSNITCH_MAX_UPLOAD_MB=50
PDFSNITCH_PUBLIC_API_BASE_URL=https://pdfsnitch-api.onrender.com
PDFSNITCH_FRONTEND_ORIGINS=https://your-vercel-domain.vercel.app

# These paths match the persistent disk in render.yaml.
PDFSNITCH_DATA_DIR=/var/data
PDFSNITCH_UPLOAD_DIR=/var/data/uploads
PDFSNITCH_MEDIA_DIR=/var/data/media
PDFSNITCH_EXPORT_DIR=/var/data/exports
PDFSNITCH_TEMP_DIR=/tmp/pdfsnitch

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SECRET_KEY=change-this-to-a-long-random-secret
ADMIN_OTP_EMAIL=your-email@example.com

# Optional SMTP settings for admin email OTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-gmail-app-password-without-spaces
SMTP_FROM_EMAIL=your-email@example.com
SMTP_USE_TLS=true
