# Optional live backend settings. This project is configured for Vercel + Render deployment.
PDFSNITCH_MAX_UPLOAD_MB=50
PDFSNITCH_PUBLIC_API_BASE_URL=https://pdfsnitch-izhk.onrender.com
PDFSNITCH_FRONTEND_ORIGINS=https://pdfsnitch.vercel.app

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SECRET_KEY=change-this-secret
ADMIN_OTP_EMAIL=

# Optional SMTP settings for email OTP login verification.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
