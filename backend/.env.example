# Optional settings. All values below are the defaults.
PDFSNITCH_MAX_UPLOAD_MB=50
PDFSNITCH_FRONTEND_ORIGINS=http://127.0.0.1:4173,http://localhost:4173,http://127.0.0.1:5173,http://localhost:5173
# PDFSNITCH_TEMP_DIR=C:\path\to\temporary\pdfsnitch

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_SECRET_KEY=change-this-secret
ADMIN_OTP_EMAIL=

# Optional SMTP settings for email OTP login verification.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
