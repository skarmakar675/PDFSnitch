# Local frontend environment variables.
# For Vercel, copy .env.vercel.example and set VITE_API_URL to your Render backend URL.
# Optional. The frontend defaults to http://127.0.0.1:8000 in local development.
VITE_API_URL=http://127.0.0.1:8000

# Optional Google AdSense settings.
# Leave blank during development. Add your real ca-pub client ID and ad slot IDs after AdSense approval.
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_SLOT_LEADERBOARD=
VITE_ADSENSE_SLOT_CONTENT=
VITE_ADSENSE_SLOT_FOOTER=
